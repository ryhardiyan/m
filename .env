# ─── FIREBASE ADMIN (Service Account) ────────────────────
FIREBASE_PROJECT_ID="<Buka Firebase Console -> Project Settings -> General. Salin tulisan Project ID di sini>"
FIREBASE_STORAGE_BUCKET="<Buka Firebase Console -> Storage. Salin link bucket Anda, contoh: namaproject.firebasestorage.app>"
FIREBASE_PRIVATE_KEY_ID="<Buka file JSON Service Account Firebase yang didownload, salin rentetan karakter dari value 'private_key_id'>"
FIREBASE_PRIVATE_KEY="<Salin isi 'private_key' dari file JSON. HARUS menyertakan -----BEGIN PRIVATE KEY----- hingga -----END PRIVATE KEY----- beserta simbol \n di dalamnya>"
FIREBASE_CLIENT_EMAIL="<Buka file JSON Service Account, salin email yang berakhiran @namaproject.iam.gserviceaccount.com>"
FIREBASE_CLIENT_ID="<Buka file JSON Service Account, salin rentetan angka panjang dari value 'client_id'>"

# ─── FIREBASE CLIENT (Web SDK) ────────────────────────────
FIREBASE_API_KEY="<Buka Firebase Console -> Project Settings -> General -> Web App. Salin nilai 'apiKey'>"
FIREBASE_AUTH_DOMAIN="<Buka Firebase Console -> Authentication -> Settings -> Authorized domains. Salin domain utama auth Anda>"
FIREBASE_PROJECT_ID_CLIENT="<Samakan nilainya dengan FIREBASE_PROJECT_ID di atas>"

